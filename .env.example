# --- Waitlist: Google Sheet (recommended) ---
# Create a Google Cloud project → APIs & Services → Enable "Google Sheets API".
# Create a service account → Keys → Add JSON key. Copy the entire JSON object
# as a single line into GOOGLE_SERVICE_ACCOUNT_JSON (or use your host's "secret" UI).
# Open the waitlist spreadsheet → Share → add the service account email
# (client_email from the JSON) as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=
# From the sheet URL: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
WAITLIST_GOOGLE_SHEET_ID=
# Optional. Default appends Timestamp, Email, Name, Phone to columns A–D on tab "waitlist".
# Match headers: Timestamp | Email | Name | Phone Number
# WAITLIST_SHEET_RANGE=waitlist!A:D

# --- Waitlist: external URL (Google Apps Script Web App, Formspree, etc.) ---
# Form POST sends fields: email, name (optional), phone (required).
# Ignored when GOOGLE_SERVICE_ACCOUNT_JSON and WAITLIST_GOOGLE_SHEET_ID are both set.
NEXT_PUBLIC_WAITLIST_FORM_ACTION=
